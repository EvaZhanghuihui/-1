rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Validation Blueprint
    function isValidQuestionRecord(data) {
      return data.userId == request.auth.uid
        && data.originalQuestion is string && data.originalQuestion.size() <= 5000
        && data.knowledgePoint is string && data.knowledgePoint.size() <= 200
        && data.subject is string && data.subject.size() <= 50
        && data.analogousQuestions is list && data.analogousQuestions.size() <= 5
        && data.createdAt == (resource == null ? request.time : resource.data.createdAt);
    }

    // 1. Questions Collection
    match /questions/{questionId} {
      allow create: if isSignedIn()
        && isValidId(questionId)
        && isValidQuestionRecord(incoming())
        && incoming().keys().hasAll(['userId', 'originalQuestion', 'knowledgePoint', 'analogousQuestions', 'createdAt'])
        && incoming().keys().size() <= 10; // Prevent shadow fields

      allow read: if isSignedIn()
        && isOwner(resource.data.userId);

      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isValidQuestionRecord(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['originalQuestion', 'knowledgePoint', 'subject', 'analogousQuestions', 'originalOptions', 'originalAnswer']);

      allow delete: if isSignedIn()
        && isOwner(existing().userId);
    }
  }
}
